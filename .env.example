# Application Configuration
APP_NAME=polis
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database Configuration
DATABASE_URL=sqlite:///polis.db
DATABASE_ECHO=false

# Vector Store Configuration
VECTOR_STORE_URL=localhost:6333

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_REASONING_ENGINE=true
ENABLE_GOVERNANCE_ENGINE=true
